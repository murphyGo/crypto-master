# Crypto Master - Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control

# =============================================================================
# Trading Mode
# =============================================================================
# Options: paper, live
TRADING_MODE=paper

# =============================================================================
# Binance API Configuration
# =============================================================================
# Live/Mainnet API credentials
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Testnet API credentials (separate from live - get from testnet.binance.vision)
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret_here
# Options: spot, futures
BINANCE_MARKET_TYPE=futures
# Options: true, false (use testnet for paper trading)
BINANCE_TESTNET=true

# =============================================================================
# Bybit API Configuration
# =============================================================================
# Live/Mainnet API credentials
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
# Testnet API credentials (separate from live - get from testnet.bybit.com)
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_API_SECRET=your_bybit_testnet_api_secret_here
# Options: true, false (use testnet for paper trading)
BYBIT_TESTNET=true

# =============================================================================
# Logging Configuration
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log file path (relative to project root)
LOG_FILE=data/logs/crypto-master.log

# =============================================================================
# Data Storage
# =============================================================================
# Base directory for all data storage
DATA_DIR=data

# =============================================================================
# Paper Trading Configuration
# =============================================================================
# Initial virtual balance for paper trading (in USDT)
PAPER_INITIAL_BALANCE=10000.0

# =============================================================================
# Risk Management
# =============================================================================
# Maximum leverage allowed
MAX_LEVERAGE=10
# Maximum position size as percentage of portfolio
MAX_POSITION_SIZE_PCT=10.0
# Default stop loss percentage
DEFAULT_STOP_LOSS_PCT=2.0

# =============================================================================
# Trading Engine Tunables (Phase 10.2)
# =============================================================================
# These map onto src.runtime.engine.EngineConfig. Defaults below match
# the hardcoded values used before Phase 10.2 — leave unset to preserve
# existing behaviour, override only when you know what you're tuning.
#
# Seconds between engine cycles (scan + decide + execute + monitor).
# Minimum 10. Default 300 (5 minutes).
ENGINE_CYCLE_INTERVAL=300
# Composite-score threshold above which proposals are auto-accepted.
# Same gate filters proposal notifications. Default 1.0.
ENGINE_AUTO_APPROVE_THRESHOLD=1.0
# Comma-separated altcoin symbol list scanned each cycle.
ENGINE_SYMBOLS=ETH/USDT,SOL/USDT,BNB/USDT,ADA/USDT,AVAX/USDT
# Notional balance used for per-cycle proposal sizing (Decimal).
# In paper mode this is independent of PAPER_INITIAL_BALANCE — the
# engine uses ENGINE_BALANCE for proposal sizing while PaperTrader
# tracks the virtual balance. Default 10000.
ENGINE_BALANCE=10000
# HARD cap on simultaneously-open positions per symbol, enforced at
# the engine execution gate (Phase 12.1). Even if the proposal engine
# emits a high-score proposal for a symbol that already has an open
# position from a previous cycle, the engine logs a PROPOSAL_REJECTED
# with a "symbol cap N reached" reason and skips opening. Phase 10.6's
# per-cycle dedup is independent of this cross-cycle cap. Minimum 1
# (default); raise only if you intentionally want to pyramid into a
# pair. Setting this to 1 is the recommended live-trading default.
ENGINE_MAX_OPEN_POSITIONS_PER_SYMBOL=1
# Phase 13.2 (DEBT-003): the remaining EngineConfig fields are also
# env-overridable. Defaults match the pre-13.2 hardcoded values, so
# leaving these unset preserves existing behaviour.
#
# Seconds between SL/TP monitor polls of open positions inside one
# cycle. Minimum 10. Default 60.
ENGINE_MONITOR_INTERVAL=60
# Symbol used for the per-cycle Bitcoin proposal scan (altcoin scans
# come from ENGINE_SYMBOLS). Default BTC/USDT.
ENGINE_BITCOIN_SYMBOL=BTC/USDT
# Top-K cap on altcoin proposals retained per cycle. The proposal
# engine ranks altcoins by composite score and truncates to this
# many. Minimum 1. Default 3.
ENGINE_ALTCOIN_TOP_K=3
# Actor name stamped onto auto-decided proposals + activity log
# events. Default "auto-engine"; override only if you run multiple
# engines against the same data dir and want to tell them apart.
ENGINE_ACTOR=auto-engine

# =============================================================================
# Log Retention (Phase 10.4)
# =============================================================================
# Number of months of activity log + audit log archives the application
# surfaces in read_all (in addition to the active month). Older rotated
# files stay on disk untouched but are not merged into the application.
# Same value drives ProposalHistory.purge_old (operator-callable
# age-based archive). Minimum 1, default 12.
LOG_RETENTION_MONTHS=12

# =============================================================================
# Notification Push Backend (Phase 11.3)
# =============================================================================
# Slack incoming-webhook URL. When unset, no Slack notifier is
# registered and the dispatcher uses only the Console + File
# backends. When set, every proposal that passes the dispatcher's
# min_score gate is also POSTed as a Slack message.
#
# Treat this URL as a secret — anyone who has it can post to your
# Slack channel. Generate one at:
#   https://api.slack.com/messaging/webhooks
#
# Example: SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00.../B00.../XX...
SLACK_WEBHOOK_URL=

# Telegram bot token + chat id pair. BOTH must be set for the
# Telegram backend to register; if either is missing the dispatcher
# silently skips Telegram and falls back to the other backends. The
# token authenticates the bot (anyone who has it can drive the bot)
# and the chat id reveals the destination chat — treat both as
# secrets. The runtime never logs either value. To set up:
#   1. Talk to @BotFather on Telegram → /newbot → copy the token.
#   2. Send any message to your bot from the destination chat.
#   3. Read the chat id from
#      https://api.telegram.org/bot<TOKEN>/getUpdates (look at
#      ``message.chat.id``).
#
# Example:
#   TELEGRAM_BOT_TOKEN=123456789:AAH...XYZ
#   TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP) push backend (Phase 13.4). ALL six fields below must be
# set for the backend to register; with any field unset, the dispatcher
# silently skips email and falls back to the other backends. The
# password is a secret — the runtime never logs it, and ``__repr__``
# on the notifier masks it. STARTTLS is the default (port 587). For an
# SMTP-over-SSL provider use the provider's documented SSL port.
#
# Gmail example (use an App Password, not your account password):
#   EMAIL_SMTP_HOST=smtp.gmail.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=you@gmail.com
#   EMAIL_SMTP_PASSWORD=your_app_password_here
#   EMAIL_FROM=Crypto Master <you@gmail.com>
#   EMAIL_TO=alerts@example.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# =============================================================================
# Claude CLI Timeout / Retry (Phase 12.3)
# =============================================================================
# Base timeout in seconds for one ``claude -p`` invocation. On timeout
# the wrapper retries up to CLAUDE_CLI_MAX_RETRIES times, multiplying
# the timeout by 1.5x each retry (e.g. 120s -> 180s -> 270s with
# max_retries=2). After the final timeout, the proposal engine logs an
# ActivityEventType.LLM_TIMEOUT event and falls back to no-proposal for
# that strategy/symbol pair. Minimum 10s. Default 120 (2 minutes).
CLAUDE_CLI_TIMEOUT_SECONDS=120
# Maximum retries on timeout. 0 means no retry (single-shot timeout).
# Default 1 (one retry, so total of 2 attempts before giving up).
CLAUDE_CLI_MAX_RETRIES=1
