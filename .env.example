# Crypto Master - Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control

# =============================================================================
# Trading Mode
# =============================================================================
# Options: paper, live
TRADING_MODE=paper

# =============================================================================
# Binance API Configuration
# =============================================================================
# Live/Mainnet API credentials
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Testnet API credentials (separate from live - get from testnet.binance.vision)
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret_here
# Options: spot, futures
BINANCE_MARKET_TYPE=futures
# Options: true, false (use testnet for paper trading)
BINANCE_TESTNET=true

# =============================================================================
# Bybit API Configuration
# =============================================================================
# Live/Mainnet API credentials
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
# Testnet API credentials (separate from live - get from testnet.bybit.com)
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_API_SECRET=your_bybit_testnet_api_secret_here
# Options: true, false (use testnet for paper trading)
BYBIT_TESTNET=true

# =============================================================================
# Logging Configuration
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log file path (relative to project root)
LOG_FILE=data/logs/crypto-master.log

# =============================================================================
# Data Storage
# =============================================================================
# Base directory for all data storage
DATA_DIR=data

# =============================================================================
# Paper Trading Configuration
# =============================================================================
# Initial virtual balance for paper trading (in USDT)
PAPER_INITIAL_BALANCE=10000.0

# =============================================================================
# Risk Management
# =============================================================================
# Maximum leverage allowed
MAX_LEVERAGE=10
# Maximum position size as percentage of portfolio
MAX_POSITION_SIZE_PCT=10.0
# Default stop loss percentage
DEFAULT_STOP_LOSS_PCT=2.0

# =============================================================================
# Trading Engine Tunables (Phase 10.2)
# =============================================================================
# These map onto src.runtime.engine.EngineConfig. Defaults below match
# the hardcoded values used before Phase 10.2 — leave unset to preserve
# existing behaviour, override only when you know what you're tuning.
#
# Seconds between engine cycles (scan + decide + execute + monitor).
# Minimum 10. Default 300 (5 minutes).
ENGINE_CYCLE_INTERVAL=300
# Composite-score threshold above which proposals are auto-accepted.
# Same gate filters proposal notifications. Default 1.0.
ENGINE_AUTO_APPROVE_THRESHOLD=1.0
# Comma-separated altcoin symbol list scanned each cycle.
ENGINE_SYMBOLS=ETH/USDT,SOL/USDT,BNB/USDT,ADA/USDT,AVAX/USDT
# Notional balance used for per-cycle proposal sizing (Decimal).
# In paper mode this is independent of PAPER_INITIAL_BALANCE — the
# engine uses ENGINE_BALANCE for proposal sizing while PaperTrader
# tracks the virtual balance. Default 10000.
ENGINE_BALANCE=10000

# =============================================================================
# Log Retention (Phase 10.4)
# =============================================================================
# Number of months of activity log + audit log archives the application
# surfaces in read_all (in addition to the active month). Older rotated
# files stay on disk untouched but are not merged into the application.
# Same value drives ProposalHistory.purge_old (operator-callable
# age-based archive). Minimum 1, default 12.
LOG_RETENTION_MONTHS=12
