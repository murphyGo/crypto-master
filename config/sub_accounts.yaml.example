# Copy to config/sub_accounts.yaml to enable multi-paper-account routing.
#
# Phase 19.3 supports multiple paper-mode sub-accounts. Live-mode
# expansion with distinct credential sets lands in Phase 19.4.

sub_accounts:
  - id: default
    name: Default Paper Account
    mode: paper
    exchange_ref: default
    initial_balance:
      USDT: 10000
    strategy_filter: null
    risk_overrides: {}
    enabled: true

  - id: btc_only
    name: BTC Swing Paper
    mode: paper
    exchange_ref: default
    capital_policy:
      initial_balance:
        USDT: 5000
      sizing_balance: 5000
    strategy_policy:
      strategy_filter:
        - chasulang_ict_smc
        - rsi_4h
      symbols:
        - BTC/USDT
        - ETH/USDT
      top_k: 2
    proposal_policy:
      auto_approve_threshold: 1.0
      notify_min_score: 1.0
    risk_policy: {}
    execution_policy: {}
    enabled: true

  - id: experimental
    name: Experimental Paper
    mode: paper
    exchange_ref: default
    capital_policy:
      initial_balance:
        USDT: 2500
      sizing_balance: 2500
    strategy_policy:
      strategy_filter: null
    # Optional. Route this sub-account's push notifications to the
    # matching key in NOTIFICATION_SLACK_WEBHOOK_URLS instead of the
    # global SLACK_WEBHOOK_URL.
    notification_policy:
      route: experimental
      min_score: 0.0
    risk_policy:
      risk_percent: 0.5
      max_open_positions_total: 1
    execution_policy:
      reject_if_past_stop_loss: false
      reject_if_stale_quote: false
    enabled: true
